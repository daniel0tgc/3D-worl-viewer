VITE_CESIUM_ION_TOKEN=
VITE_GOOGLE_MAPS_API_KEY=

# OpenSky — browser (npm run dev only): direct API + OAuth from the client
# Register at https://opensky-network.org — API client at https://opensky-network.org/profile
VITE_OPENSKY_CLIENT_ID=
VITE_OPENSKY_CLIENT_SECRET=

# OpenSky — Vercel serverless only (no VITE_ prefix; not exposed to the browser bundle).
# Set these in Vercel Project → Environment Variables for Production (same values as above is fine).
# Used by api/opensky/* to attach Bearer token; if unset, proxy calls OpenSky anonymously.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Google Maps: restrict key by HTTP referrer — include https://YOUR-APP.vercel.app/* and https://*.vercel.app/* for previews
